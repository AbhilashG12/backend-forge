generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "mysql"
  
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  name         String?
  role         String
  passwordHash String
  createdAt    DateTime       @default(now())
  tokens       RefreshToken[] // Relation to RefreshTokens
  
  @@map("users") 
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@map("refresh_tokens")
}